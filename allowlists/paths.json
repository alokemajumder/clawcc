{
  "_comment": "Filesystem path allowlists - add paths for any AI agent you manage",
  "allowed": [
    "~/.claude",
    "~/.config/claude",
    "~/.codex",
    "~/.copilot",
    "~/.config/github-copilot",
    "~/.cursor",
    "~/.config/cursor",
    "~/.codeium",
    "~/.gemini",
    "~/.augment",
    "~/.kiro",
    "~/.aws/amazonq",
    "~/.config/TabNine",
    "~/.openclaw",
    "~/.zeroclaw",
    "~/.nanobot",
    "~/.nemoclaw",
    "~/.continue",
    "~/.openhands",
    "~/.tabby",
    "~/.tabby-client",
    "~/.config/goose",
    "~/.config/opencode",
    "~/Documents/Cline",
    "/var/log/clawcc",
    "/tmp/clawcc"
  ],
  "protected": [
