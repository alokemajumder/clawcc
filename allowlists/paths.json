    "~/.augment/settings.json",
    "~/.config/opencode/auth.json",
    "~/.zeroclaw/config.toml",
    "~/.nanobot/config.json"
  ],
  "forbidden": [
    "~/.ssh",
    "~/.gnupg",
    "~/.aws",
    "/etc/shadow",
    "/etc/passwd"
  ]
}
